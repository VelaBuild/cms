APP_NAME="Vela CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Template
SITE_TEMPLATE=default

# Logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vela
DB_USERNAME=root
DB_PASSWORD=

# Drivers
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Redis (optional)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AI Services (at least one text provider recommended)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AI_TEXT_PROVIDER=openai
AI_IMAGE_PROVIDER=gemini

# Site Context (used in AI-generated content)
SITE_NAME="My Website"
SITE_NICHE=general
SITE_DESCRIPTION=

# Figma Integration (optional)
FIGMA_ACCESS_TOKEN=

# Static Site Generation
VELA_CACHE=true

# Image Optimization
VELA_IMAGES_ENABLED=true
